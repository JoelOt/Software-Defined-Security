# Snort 3 Local Rules for Federated SDN Quarantine VNF

# 1. High-Volume UDP Traffic (Simulated DoS)
# Tracks by source IP. Alerts if a source sends more than 100 UDP packets in 1 second.
alert udp any any -> any any (msg:"High-Volume UDP Traffic (Possible DoS)"; detection_filter:track by_src, count 100, seconds 1; classtype:denial-of-service; sid:1000001; rev:1;)

# 2. ICMP Echo Request (Basic Lateral Movement)
# Alerts on any ICMP Echo Request (itype:8). Useful for catching ping sweeps in the quarantine zone.
alert icmp any any -> any any (msg:"ICMP Echo Request - Possible Lateral Movement"; itype:8; classtype:icmp-event; sid:1000002; rev:1;)
