# ── Trust Plane (Geth / DLT) ───────────────────────────────────────────────
DLT_RPC_URL=http://127.0.0.1:8545
DLT_WS_URL=ws://127.0.0.1:8546
CONTRACT_ADDRESS=""

# Geth Docker configuration
GETH_CONTAINER_NAME=geth-poa
GETH_DOCKER_IMAGE=ethereum/client-go:v1.13.15
GETH_NETWORK_ID=12345
GETH_CHAIN_PERIOD=1
GETH_ACCOUNT_PASSWORD=testpassword

# ── Control Plane (Ryu) ───────────────────────────────────────────────────
MININET_CONTROLLER_IP=127.0.0.1
TELEMETRY_PPS_THRESHOLD=500

# Mock mode for running without a real Geth network (0 = false, 1 = true)
USE_TEST_DLT=0

# Note: LOCAL_SUBNET_PREFIX is intentionally omitted from this file.
# Because multiple controllers run from the same directory, it must be
# passed inline (e.g., LOCAL_SUBNET_PREFIX="10.0.1." ryu-manager ...)
