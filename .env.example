DLT_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=""
MININET_CONTROLLER_IP=127.0.0.1
TELEMETRY_PPS_THRESHOLD=500

# Mock mode for running without a real Geth network (0 = false, 1 = true)
USE_TEST_DLT=0

# Orchestrated DLT mode based on the DLT integration branch.
# When enabled, controllers expose a local API and wait for sdn/NetworkOrchestrator.py
# to push generated account credentials and contract metadata at runtime.
USE_DLT_ORCHESTRATOR=0
SDN_API_HOST=127.0.0.1
SDN_API_PORTS=5000,5001
DLT_AGENT_NAMES=DomainA,DomainB
DLT_ORCHESTRATOR_RPC_URL=http://127.0.0.1:8545
# Set only in your local .env when using a locked/private PoA network.
# Never commit real private keys.
DLT_ORCHESTRATOR_PRIVATE_KEY=
CHAIN_ID=

# Note: LOCAL_SUBNET_PREFIX is intentionally omitted from this file.
# Because multiple controllers run from the same directory, it must be 
# passed inline (e.g., LOCAL_SUBNET_PREFIX="10.0.1." ryu-manager ...)
