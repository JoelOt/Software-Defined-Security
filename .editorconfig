# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# Python and Bash: 4 spaces
[*.{py,sh}]
indent_style = space
indent_size = 4

# Solidity: 2 spaces
[*.sol]
indent_style = space
indent_size = 2
